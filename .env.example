# ------------------------------------------------------------------------------
# User Configuration (Required)
# ------------------------------------------------------------------------------
# Authentication token
TOKEN=

# Project identifier
PROJECT_ID=


# ------------------------------------------------------------------------------
# Program Configuration (Required)
# ------------------------------------------------------------------------------
# Program ID obtained after uploading your zkVM program
PROGRAM_ID=


# ------------------------------------------------------------------------------
# Others (Optional)
# ------------------------------------------------------------------------------

# Verbose logging (0 = disabled, 1, 2, etc.)
LOG_VERBOSE=0

# zkVM service endpoint
ZKVM_SERVICE_URL=https://api-por.primuslabs.xyz:38080


# ------------------------------------------------------------------------------
# Blockchain Configuration (Optional)
# ------------------------------------------------------------------------------

# Default: Base Mainnet
RPC_URL=https://mainnet.base.org

# Wallet private key (required only when submitting results on-chain)
PRIVATE_KEY=0x


# ------------------------------------------------------------------------------
# zkTLS Mode
# ------------------------------------------------------------------------------
# zkTLS mode selection: POR(default), DVC
# If ZKTLS_MODE is set to DVC, PRIVATE_KEY must be configured.
ZKTLS_MODE=POR
